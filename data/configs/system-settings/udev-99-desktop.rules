# Raise audio card priority
ACTION=="add", SUBSYSTEM=="sound", KERNEL=="card*", ATTR{priority}="10"

# Set GPU to high performance
ACTION=="add", SUBSYSTEM=="drm", KERNEL=="card*", ATTR{device/power_dpm_force_performance_level}="high"

# Power saving for USB
ACTION=="add", SUBSYSTEM=="usb", ATTR{power/control}="auto"

# Power saving for PCI
ACTION=="add", SUBSYSTEM=="pci", ATTR{power/control}="auto"
