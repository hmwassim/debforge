#!/usr/bin/env bash
# ksmctl — enable/disable/pause/status for Kernel Same-page Merging
# Source: CachyOS (Vasiliy Stelmachenok), GPLv2+

file_path="/sys/kernel/mm/ksm/run"

die() {
    echo "$@" >&2
    exit 1
}

help() {
    die "$(cat << EOF
Usage: $0 {--enable|-e|--disable|-d|--status|-s|--pause|-p|--help|-h}
  --enable,  -e :  Enable KSM
  --disable, -d :  Disable KSM (unmerge all pages)
  --pause,   -p :  Pause KSM without unmerging pages
  --status,  -s :  Print the current KSM status
  --help,    -h :  Print this message
EOF
)"
}

if [ "$#" -eq 0 ]; then
    help
fi

while [[ "$#" -gt 0 ]]; do
    case "$1" in
        --pause | -p)
            new_state="0"
            shift
            ;;
        --enable | -e)
            new_state="1"
            shift
            ;;
        --disable | -d)
            new_state="2"
            shift
            ;;
        --help | -h)
            help
            ;;
        --status | -s)
            status="Unknown KSM state"
            case "$(cat "$file_path")" in
                0) status="KSM paused (merged tables kept)" ;;
                1) status="KSM enabled and running" ;;
                2) status="KSM disabled (merged tables unmerged)" ;;
                *) ;;
            esac
            echo "$status"
            exit 0
            ;;
        *)
            die "Error: Invalid argument. Use --enable, --disable, --pause, --status or --help."
            ;;
    esac
done

if [ "$(id -u)" -ne 0 ]; then
    die "Error: This script must be run with root privileges."
fi

if [ -z "$new_state" ]; then
    die "Error: Missing action. Use --enable, --disable or --pause"
fi

if ((new_state == 0)); then
    echo "Pausing Kernel Samepage Merging..."
    echo "0" > "$file_path"
elif ((new_state == 1)); then
    echo "Enabling Kernel Samepage Merging..."
    echo "1" > "$file_path"
else
    echo "Disabling Kernel Samepage Merging..."
    echo "2" > "$file_path"
fi
