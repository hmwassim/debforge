#!/usr/bin/env sh
# Adjust PCI latency timers to reduce audio latency.
# - Default all PCI devices to 20 cycles (from vendor-set values that may be high).
# - Root bus to 0.
# - Sound cards (PCI class 04xx) to 80 cycles (generous for uninterrupted DMA).
# Source: CachyOS-Settings

if [ "$(id -u)" -ne 0 ]; then
    echo "Error: This script must be run with root privileges." >&2
    exit 1
fi

setpci -v -s '*:*' latency_timer=20
setpci -v -s '0:0' latency_timer=0
setpci -v -d "*:*:04xx" latency_timer=80
